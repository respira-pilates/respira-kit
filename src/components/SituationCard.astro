---
interface Props {
  icon: string
  title: string
  benefit: string
  vimeoId: string
}
const { icon, title, benefit, vimeoId } = Astro.props
---

<article class="card" data-vimeo-id={vimeoId}>
  <div class="card__icon">{icon}</div>
  <h3 class="card__title">{title}</h3>
  <p class="card__benefit">{benefit}</p>
  <button class="card__btn" data-vimeo-trigger aria-label={`Ver clase: ${title}`}>
    Ver clase
  </button>
  <div class="vimeo-container"></div>
</article>

<script>
  document.querySelectorAll('[data-vimeo-trigger]').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('[data-vimeo-id]') as HTMLElement
      const id = card.dataset.vimeoId
      const container = card.querySelector('.vimeo-container') as HTMLElement
      container.innerHTML = `
        <div style="padding:56.25% 0 0 0;position:relative;margin-top:1rem;">
          <iframe
            src="https://player.vimeo.com/video/${id}?controls=1&title=0&byline=0&portrait=0&autoplay=1&muted=1"
            style="position:absolute;top:0;left:0;width:100%;height:100%;"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>`
      ;(btn as HTMLElement).style.display = 'none'
    })
  })
</script>

<style>
.card {
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-card);
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.card:hover {
  border-color: var(--color-accent);
  box-shadow: 0 4px 20px rgba(178, 223, 226, 0.25);
}

.card__icon { font-size: 2rem; line-height: 1; }

.card__title {
  font-size: 1.05rem;
  font-weight: 400;
  letter-spacing: 0.02em;
}

.card__benefit {
  font-size: 0.9rem;
  opacity: 0.8;
  line-height: 1.65;
  flex: 1;
}

.card__btn {
  margin-top: var(--space-xs);
  align-self: flex-start;
  background: transparent;
  color: var(--color-text);
  border: 1.5px solid var(--color-text);
  border-radius: var(--radius-btn);
  padding: 0.5rem 1.25rem;
  font-family: var(--font-primary);
  font-size: 0.8rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
}

.card__btn:hover {
  background: var(--color-text);
  color: var(--color-white);
}
</style>
